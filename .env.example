# Copy to `.env` in this folder (gitignored). Only names starting with VITE_ are exposed to the app.
# Restart `npm run dev` after editing `.env`.
#
# Vercel WITHOUT saving keys in the Vercel dashboard:
#   1) `npx vercel login` and `npx vercel link` once in this repo.
#   2) Keep secrets only in local `.env` (never commit `.env`).
#   3) Deploy with: `npm run deploy:vercel` — builds on YOUR machine (reads `.env`), then uploads
#      the prebuilt output. Git-triggered Vercel builds still cannot see your laptop `.env`.
#
# Note: VITE_* values are still embedded in the public JS bundle (same as any client-side key).
# Google Maps Platform key — must have Maps JavaScript API, Places API, Maps Static API,
# and Solar API all enabled in Google Cloud Console.
VITE_GOOGLE_MAPS_API_KEY=
# Gemini: any of these names is merged at build time (Google AI Studio often uses GEMINI_API_KEY):
VITE_GOOGLE_AI_KEY=
GEMINI_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=
# OpenAI (used only as fallback when Gemini returns 429/quota).
# Local `npm run dev`: use OPENAI_API_KEY or OPENAI_KEY in `.env` (no VITE_ needed).
# Vercel: set OPENAI_API_KEY in the project environment (server-only).
OPENAI_API_KEY=
# OPENAI_KEY=
# Either name works for Neon (vite.config merges into the client bundle):
VITE_DATABASE_URL=
DATABASE_URL=
# HOVER API — server-only (no VITE_ prefix = never sent to browser). Get key at developer.hover.to
HOVER_API_KEY=
# Replicate — server-only. Get token at replicate.com/account/api-tokens
REPLICATE_API_TOKEN=
# 3D Depth Pipeline (Python / Railway microservice). Set to your Railway deployment URL.
VITE_DEPTH_SERVICE_URL=
