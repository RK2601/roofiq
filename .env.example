# Copy to `.env` in this folder (gitignored). Only names starting with VITE_ are exposed to the app.
# Restart `npm run dev` after editing `.env`.
#
# Vercel: add the SAME variable names in Project → Settings → Environment Variables
# for Production and Preview (and redeploy). Vite inlines them at BUILD time — a .env
# file on your machine does not apply to Vercel unless you use `vercel env pull` + commit (not recommended for secrets).
VITE_GOOGLE_MAPS_API_KEY=
VITE_GOOGLE_AI_KEY=
VITE_DATABASE_URL=
